# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_ORIGIN=http://localhost:3000

# Vector memory
# Use local:<directory> without Docker, or an http(s) URL for hosted/Docker Qdrant.
QDRANT_URL=local:qdrant_storage
QDRANT_API_KEY=
QDRANT_COLLECTION=customer_memory
MEMORY_BACKEND=qdrant

# AI provider (optional; deterministic fallbacks work without a key)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
LYZR_API_KEY=
LYZR_AGENT_ID=
LYZR_API_URL=https://agent-prod.studio.lyzr.ai/v3/inference/chat/
LYZR_USER_ID=retailmind-demo
